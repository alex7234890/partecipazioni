# Copia questo file in .env.local e compila i valori

# Supabase — ottieni da: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Solo per le Edge Functions (non esporre al frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Resend API — ottieni da: https://resend.com/api-keys
RESEND_API_KEY=re_...

# URL del sito in produzione (usato nei link delle email)
WEDDING_URL=https://il-tuo-sito.vercel.app
FROM_EMAIL=noreply@matteoeclio.it
